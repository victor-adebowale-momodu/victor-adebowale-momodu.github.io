---
import { getCollection } from "astro:content";
import CollectionHeader from "@/components/common/CollectionHeader.astro";
import Content from "@/components/sections/projects/Content.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

export async function getStaticPaths() {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { title, tags } = project.data;
---

<BaseLayout>
    <CollectionHeader heading={title} tags={tags} />
    <Content {...project.data} />
</BaseLayout>
