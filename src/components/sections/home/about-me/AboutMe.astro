---
import "./styles.css";
import githubIcon from "@/assets/github.svg?raw";
import linkedinIcon from "@/assets/linkedin.svg?raw";
import twitterIcon from "@/assets/twitter.svg?raw";
import emailIcon from "@/assets/email.svg?raw";
import linkIcon from "@/assets/link.svg?raw";
import ThemedIcon from "@/components/icons/ThemedIcon.astro";

const socialLinks = [
    {
        icon: githubIcon,
        alt: "GitHub",
        url: "https://github.com/victor-adebowale-momodu",
    },
    {
        icon: linkedinIcon,
        alt: "LinkedIn",
        url: "https://linkedin.com/in/victor-adebowale-momodu",
    },
    {
        icon: twitterIcon,
        alt: "Twitter",
        url: "https://twitter.com/victor-adebowale-momodu",
    },
    {
        icon: emailIcon,
        alt: "Email",
        url: "mailto:victor@adebowale-momodu.com",
    },
];
---

<section class="about-me">
    <div class="container">
        <a href="/about-me" class="headingLink">
            <h2 class="heading">
                About Me
                <ThemedIcon icon={linkIcon} alt="Link" size="small" />
            </h2>
        </a>
        <div class="content">
            <div class="column">
                <p>
                    <strong>Victor Adebowale Momodu</strong> is a software engineer
                    focused on building fast, thoughtful, and scalable digital products.
                </p>

                <p>
                    With a strong foundation in modern software development,
                    Victor works across frontend and backend systems, using
                    tools and languages like Astro, JavaScript, TypeScript,
                    Python, and Golang to create reliable and maintainable
                    solutions.
                </p>
            </div>
            <div class="column">
                <p>
                    Working across the intersection of design and engineering,
                    Victor brings precision, curiosity, and strong technical
                    thinking to every project.
                </p>

                <p>
                    Inspired by <a href="https://nomoredesign.co.uk"
                        >nomoredesign</a
                    >
                </p>

                <div class="socials">
                    {
                        socialLinks.map((link) => (
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <ThemedIcon
                                    icon={link.icon}
                                    alt={link.alt}
                                    color="primary"
                                />
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>
