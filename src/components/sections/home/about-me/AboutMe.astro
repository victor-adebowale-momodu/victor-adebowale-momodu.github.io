---
import styles from "./AboutMe.module.css";
import githubIcon from "@/assets/github.svg?raw";
import linkedinIcon from "@/assets/linkedin.svg?raw";
import twitterIcon from "@/assets/twitter.svg?raw";
import emailIcon from "@/assets/email.svg?raw";
import linkIcon from "@/assets/link.svg?raw";
import IconPrimary from "@/components/icons/IconPrimary.astro";
---

<section class={styles.aboutMe}>
    <div class="container">
        <a href="/about-me" class="headingLink">
            <h2 class="heading">
                About Me
                <IconPrimary icon={linkIcon} alt="Link" size="small" />
            </h2>
        </a>
        <div class={styles.content}>
            <div class={styles.left}>
                <p>
                    <strong>Victor Adebowale Momodu</strong> is a software engineer
                    focused on building fast, thoughtful, and scalable digital products.
                </p>

                <p>
                    With a strong foundation in modern software development,
                    Victor works across frontend and backend systems, using
                    tools and languages like Astro, JavaScript, TypeScript,
                    Python, and Golang to create reliable and maintainable
                    solutions.
                </p>
            </div>
            <div class={styles.right}>
                <p>
                    Working across the intersection of design and engineering,
                    Victor brings precision, curiosity, and strong technical
                    thinking to every project.
                </p>

                <div class={styles.socials}>
                    <a
                        href="https://github.com/victor-adebowale-momodu"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <IconPrimary icon={githubIcon} alt="GitHub" />
                    </a>

                    <a
                        href="https://linkedin.com/in/victor-adebowale-momodu"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <IconPrimary icon={linkedinIcon} alt="LinkedIn" />
                    </a>

                    <a
                        href="https://twitter.com/victoramomodu"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <IconPrimary icon={twitterIcon} alt="Twitter" />
                    </a>

                    <a
                        href="mailto:victoramomodu@gmail.com"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <IconPrimary icon={emailIcon} alt="Email" />
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
