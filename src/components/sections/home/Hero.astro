---
import { getCollection } from "astro:content";

const quotesCollection = await getCollection("quotes");
const quotes = quotesCollection.map((quote) => quote.data);
---

<section class="hero">
    <div class="container">
        <blockquote class="quote">
            <p id="quote-text">
                {quotes.length === 0 ? "No quotes yet." : "Loading..."}
            </p>
            <cite id="quote-author"></cite>
        </blockquote>
    </div>
</section>

<style>
    .hero {
        height: 100vh;
        display: flex;
        align-items: center;
        padding-bottom: 8vh;
    }

    .quote {
        max-width: 1000px;
        text-align: center;
    }

    .quote p {
        font-size: clamp(1.75rem, 8vw, 3.5rem);
        font-weight: 800;
    }

    .quote cite {
        display: block;
        font-style: normal;
        font-weight: bold;
        opacity: 0.7;
    }
</style>

<script is:inline define:vars={{ quotes }}>
    function generateRandomQuote() {
        const randomQuote = quotes[Math.floor(Math.random() * quotes.length)];
        const textEl = document.getElementById("quote-text");
        const authorEl = document.getElementById("quote-author");
        if (textEl && authorEl) {
            textEl.innerText = randomQuote.text;
            authorEl.innerText = randomQuote.author;
        }
    }

    generateRandomQuote();
</script>
