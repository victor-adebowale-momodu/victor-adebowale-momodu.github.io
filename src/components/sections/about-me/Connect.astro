---
import emailIcon from "@/assets/icons/email.svg?raw";
import whatsappIcon from "@/assets/icons/whatsapp.svg?raw";
import ThemedIcon from "@/components/common/ThemedIcon.astro";
---

<section class="connect-section">
    <div class="container connect-wrapper">
        <div class="connect-action">
            <h2 class="connect-heading">Connect with me:</h2>
            <div class="connect-links">
                <a
                    href="https://wa.me/+2348164998936"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Chat on WhatsApp"
                >
                    start a chat
                    <ThemedIcon
                        icon={whatsappIcon}
                        alt="whatsapp"
                        size="small"
                    />
                </a>
                <a
                    href="mailto:victoramomodu@gmail.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Send an Email"
                >
                    send a mail
                    <ThemedIcon
                        icon={emailIcon}
                        alt="email"
                        color="secondary"
                        size="small"
                    />
                </a>
            </div>
        </div>

        <div class="connect-status">
            <p class="status-text">&lt; Based in Ife, Nigeria. &gt;</p>
            <p class="status-text">&lt; Available everywhere. &gt;</p>
            <p class="status-text">
                &lt; Open to new projects and collaborations. &gt;
            </p>
        </div>
    </div>
</section>

<style>
    .connect-section {
        padding-block: clamp(4rem, 8vw, 8rem);
    }

    .connect-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 3rem;
    }

    .connect-action {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .connect-heading {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 500;
        margin: 0;
    }

    .connect-links {
        display: flex;
        gap: 2rem;
        align-items: center;
    }

    .connect-links a {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 1.15rem;
        font-weight: 500;
        text-decoration: underline dotted;
        text-underline-offset: 0.5rem;
        color: var(--color-secondary);
        border-bottom: 1px solid var(--color-primary);
        padding-bottom: 2px;

        transition:
            border-color 0.2s ease,
            opacity 0.2s ease,
            transform 0.2s ease;
    }

    .connect-links a:hover {
        opacity: 0.8;
        border-color: transparent;
        text-underline-offset: 0.25rem;
        text-decoration: underline solid;
        transform: translateY(-2px);
    }

    .connect-status {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 45ch;
    }

    .status-text {
        font-size: clamp(1rem, 2vw, 1.3rem);
        line-height: 1.4;
        margin: 0;
        opacity: 0.8;
        font-style: italic;
    }

    @media (max-width: 768px) {
        .connect-wrapper {
            flex-direction: column;
            gap: 3rem;
        }

        .connect-status {
            max-width: 100%;
        }
    }
</style>
