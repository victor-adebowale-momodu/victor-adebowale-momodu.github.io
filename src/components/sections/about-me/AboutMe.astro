---
import githubIcon from "@/assets/icons/github.svg?raw";
import linkedinIcon from "@/assets/icons/linkedin.svg?raw";
import twitterIcon from "@/assets/icons/twitter.svg?raw";
import linkIcon from "@/assets/icons/link.svg?raw";
import ThemedIcon from "@/components/common/ThemedIcon.astro";

interface Props {
    showHeading?: boolean;
}

const { showHeading = true } = Astro.props;

const socialLinks = [
    {
        icon: githubIcon,
        alt: "GitHub",
        url: "https://github.com/victor-adebowale-momodu",
    },
    {
        icon: linkedinIcon,
        alt: "LinkedIn",
        url: "https://linkedin.com/in/victor-adebowale-momodu",
    },
    {
        icon: twitterIcon,
        alt: "Twitter",
        url: "https://twitter.com/victor-adebowale-momodu",
    },
];
---

<section>
    <div class="container">
        {
            showHeading && (
                <a href="/about-me" class="heading-link">
                    <h2 class="heading">
                        About Me
                        <ThemedIcon icon={linkIcon} alt="link" size="small" />
                    </h2>
                </a>
            )
        }
        <div class="content">
            <div class="column">
                <p>
                    <strong>Victor Adebowale Momodu</strong> is a software engineer
                    focused on building performant, thoughtful, and scalable digital
                    products.
                </p>

                <p>
                    With strong experience in TypeScript/JavaScript, Python, and
                    Golang, Victor works across a wide range of systems—from
                    interactive frontend applications to backend services and
                    APIs—building reliable and maintainable software across the
                    stack.
                </p>
            </div>
            <div class="column">
                <p>
                    Victor brings a structured and detail-oriented approach to
                    engineering, with a strong emphasis on clear architecture,
                    maintainable code, and deep technical understanding.
                    Victor’s work is shaped by careful thinking, consistency,
                    and an ability to translate complex requirements into
                    well-organized systems.
                </p>

                <div class="socials">
                    {
                        socialLinks.map((link) => (
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <ThemedIcon
                                    icon={link.icon}
                                    alt={link.alt}
                                    color="primary"
                                />
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    section {
        background-color: var(--color-secondary);
        color: var(--color-primary);
        padding: clamp(4rem, 8vw, 8rem);
    }

    .content {
        display: flex;
        gap: 1.5rem;
    }

    .column {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    p {
        margin: 0;
        font-size: clamp(1rem, 1.4vw, 1.25rem);
        line-height: 1.7;
        max-width: 60ch;
    }

    .socials {
        display: flex;
        align-items: center;
        gap: 3rem;
        margin-top: 2rem;
    }

    .socials a {
        display: flex;
        align-items: center;
        justify-content: center;
        transition:
            opacity 0.2s ease,
            transform 0.2s ease;
    }

    .socials a:hover {
        opacity: 0.7;
        transform: translateY(-2px);
    }

    @media (max-width: 768px) {
        .content {
            flex-direction: column;
        }
    }
</style>
