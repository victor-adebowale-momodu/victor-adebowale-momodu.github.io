---
interface Props {
	title: string;
	description: string;
	url: string;
}
const { title, description, url } = Astro.props;
---

<a href={url}>
    <span>{title}</span>
    <p>{description}</p>
</a>
<style>
    a {
        display: flex;
        flex-direction: column;
        gap: clamp(0.75rem, 2vw, 1.5rem);
        padding: clamp(1.25rem, 4vw, 2rem);
        align-items: flex-start;
        justify-content: space-between;
        border: 1px solid transparent;
        color: var(--color-secondary);
        text-decoration: none;
        background:
            linear-gradient(to right, #000 12px, transparent 12px) 0 0/12px 3px
                no-repeat,
            linear-gradient(to bottom, #000 12px, transparent 12px) 0 0/3px 12px
                no-repeat,
            linear-gradient(to left, #000 12px, transparent 12px) 100% 0/12px
                3px no-repeat,
            linear-gradient(to bottom, #000 12px, transparent 12px) 100% 0/3px
                12px no-repeat,
            linear-gradient(to right, #000 12px, transparent 12px) 0 100%/12px
                3px no-repeat,
            linear-gradient(to top, #000 12px, transparent 12px) 0 100%/3px 12px
                no-repeat,
            linear-gradient(to left, #000 12px, transparent 12px) 100% 100%/12px
                3px no-repeat,
            linear-gradient(to top, #000 12px, transparent 12px) 100% 100%/3px
                12px no-repeat;
    }

    span {
        font-size: clamp(1.125rem, 1rem + 1vw, 1.5rem);
        line-height: 1.4;
        font-weight: 700;
    }

    p {
        font-size: clamp(1rem, 0.9rem + 0.5vw, 1.25rem);
        line-height: 1.5;
        max-width: 80ch;
    }

    a:hover {
        background-color: var(--color-secondary);
        color: var(--color-primary);
        transform: scale(1.01);
        transition: transform 0.2s ease-in-out;
    }

    @media (min-width: 768px) {
        a {
            flex-direction: row;
            align-items: center;
            gap: 1.5rem;
            padding: 2rem;
        }

        span {
            font-size: 1.5rem;
        }

        p {
            font-size: 1.25rem;
        }

        a {
            background:
                linear-gradient(to right, #000 20px, transparent 20px) 0 0/20px
                    4px no-repeat,
                linear-gradient(to bottom, #000 20px, transparent 20px) 0 0/4px
                    20px no-repeat,
                linear-gradient(to left, #000 20px, transparent 20px) 100%
                    0/20px 4px no-repeat,
                linear-gradient(to bottom, #000 20px, transparent 20px) 100%
                    0/4px 20px no-repeat,
                linear-gradient(to right, #000 20px, transparent 20px) 0
                    100%/20px 4px no-repeat,
                linear-gradient(to top, #000 20px, transparent 20px) 0 100%/4px
                    20px no-repeat,
                linear-gradient(to left, #000 20px, transparent 20px) 100%
                    100%/20px 4px no-repeat,
                linear-gradient(to top, #000 20px, transparent 20px) 100%
                    100%/4px 20px no-repeat;
        }
    }
</style>
