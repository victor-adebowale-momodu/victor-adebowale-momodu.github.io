---
const { icon, alt, size = "medium" } = Astro.props;

const sizeMap: Record<string, string> = {
    small: "24px",
    medium: "clamp(32px, 5vw, 48px)",
    large: "64px",
};
---

<span class="icon-wrapper" set:html={icon} aria-label={alt} />

<style define:vars={{ size: sizeMap[size] }}>
    .icon-wrapper {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: var(--size);
        height: var(--size);
    }

    .icon-wrapper :global(svg) {
        width: 100%;
        height: 100%;
        fill: var(--color-secondary);
    }
</style>
