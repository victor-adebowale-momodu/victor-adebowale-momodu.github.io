---
interface Props {
    icon: string;
    alt: string;
    size?: "small" | "medium" | "large";
    width?: string;
    height?: string;
    color?: "primary" | "secondary";
}

const {
    icon,
    alt,
    size = "medium",
    width,
    height,
    color = "primary",
} = Astro.props;

const sizeMap = {
    small: "24px",
    medium: "clamp(32px, 5vw, 48px)",
    large: "64px",
};

const resolvedSize = sizeMap[size];
const resolvedWidth = width ?? resolvedSize;
const resolvedHeight = height ?? resolvedSize;

const colorVar =
    color === "secondary" ? "var(--color-secondary)" : "var(--color-primary)";
---

<span class="icon-wrapper" set:html={icon} aria-label={alt} />

<style
    define:vars={{
        width: resolvedWidth,
        height: resolvedHeight,
        iconColor: colorVar,
    }}
>
    svg,
    img {
        max-width: 100%;
        height: auto;
    }

    .icon-wrapper {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: var(--width);
        height: var(--height);
    }

    .icon-wrapper :global(svg) {
        width: 100%;
        height: 100%;
        fill: var(--iconColor);
    }
</style>
